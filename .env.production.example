# Logstack API — production .env for EC2 (docker-compose.host.yml)
# Copy to .env on the server: cp .env.production.example .env && nano .env
#
# Generate secrets: openssl rand -base64 32

# ── Domain & TLS (host nginx + certbot) ───────────────────────────────────────
API_DOMAIN=api.logstack.tech
CERTBOT_EMAIL=you@logstack.tech
API_HOST_PORT=8082

# ── Database (Docker Postgres — internal hostname: postgres) ─────────────────
POSTGRES_USER=logstack
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=logstack
DATABASE_URL=postgres://logstack:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/logstack?sslmode=disable

# ── Redis (Docker — internal hostname: redis) ───────────────────────────────
REDIS_URL=redis://redis:6379

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_OPENSSL_RAND_BASE64_32

# ── Public URLs (used in emails, webhooks, notifications) ────────────────────
BASE_URL=https://api.logstack.tech
PAYSTACK_WEBHOOK_URL=https://api.logstack.tech/v1/webhooks/paystack

# CORS: * allows browser SDKs from any origin (ingest keys are the gate).
ALLOWED_ORIGINS=*

# ── Optional integrations ──────────────────────────────────────────────────────
BREVO_API_KEY=
FCM_SERVICE_ACCOUNT_PATH=
FCM_PROJECT_ID=
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_JSON=true
ENV=production