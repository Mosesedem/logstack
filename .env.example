# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║                          LOGSTACK CONFIGURATION                           ║
# ╠═══════════════════════════════════════════════════════════════════════════╣
# ║  Copy this file to .env and update the values for your environment.       ║
# ║  See: https://logstack.tech/docs/deployment/production-checklist         ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
# Connection string for PostgreSQL database.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=MODE
# 
# sslmode options:
#   - disable:     No SSL (development only)
#   - require:     SSL required (recommended for production)
#   - verify-full: SSL with certificate verification (most secure)
#
# Examples:
#   Local (Neon):  postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
#   Docker prod:   postgres://logstack:STRONG_PASSWORD@postgres:5432/logstack?sslmode=disable
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Connection pool settings (tune based on your workload)
DB_MAX_IDLE_CONNS=10        # Maximum idle connections in pool
DB_MAX_OPEN_CONNS=100       # Maximum open connections to database
DB_CONN_MAX_LIFE=30m        # Maximum lifetime of a connection

# ─────────────────────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────────────────────
# Connection string for Redis (used for caching, rate limiting, pub/sub).
# Format: redis://[:PASSWORD@]HOST:PORT[/DATABASE]
#
# Examples:
#   Local (Upstash): rediss://default:TOKEN@xxx.upstash.io:6379
#   Docker prod:     redis://redis:6379
REDIS_URL=rediss://default:TOKEN@xxx.upstash.io:6379
REDIS_POOL_SIZE=10          # Number of connections in Redis pool

# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION (JWT)
# ─────────────────────────────────────────────────────────────────────────────
# ⚠️  SECURITY: Generate unique secrets for production!
# Run: openssl rand -base64 32
#
# JWT_SECRET: Used to sign access and refresh tokens
# Must be at least 32 characters. Keep this secret!
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Token expiration times
# Format: Go duration (e.g., 15m, 1h, 24h, 7d)
ACCESS_TOKEN_EXPIRY=15m     # Short-lived access token (15 minutes recommended)
REFRESH_TOKEN_EXPIRY=168h   # Long-lived refresh token (7 days = 168h)

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL NOTIFICATIONS (Resend)
# ─────────────────────────────────────────────────────────────────────────────
# Resend API key for sending email notifications and alerts.
# Get your API key at: https://resend.com/api-keys
#
# Leave empty to disable email notifications.
RESEND_API_KEY=re_xxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# PUSH NOTIFICATIONS (Firebase Cloud Messaging)
# ─────────────────────────────────────────────────────────────────────────────
# Firebase Cloud Messaging server key for mobile push notifications.
# Get your key from: Firebase Console → Project Settings → Cloud Messaging
#
# Leave empty to disable push notifications.
FCM_SERVER_KEY=AAAAxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
PORT=8080                   # HTTP server port (inside the API container)

# EC2 / shared-host Docker: host port bound to the API container (container still uses 8080).
# Default 8082 avoids conflicts when 8080, 8081, 3000, 3001, 4000, 4040 are already taken.
API_HOST_PORT=8082

# Environment mode
# Options: development | production
# - development: Verbose logging, relaxed CORS
# - production:  JSON logging, strict security
ENV=development

# CORS allowed origins (comma-separated)
# ⚠️  SECURITY: Never use * in production!
# Examples:
#   Development: http://localhost:3000,http://localhost:8080
#   Production:  https://your-domain.com,https://www.your-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# HTTP timeouts (prevent slow client attacks)
READ_TIMEOUT=15s            # Maximum time to read request
WRITE_TIMEOUT=15s           # Maximum time to write response
IDLE_TIMEOUT=60s            # Keep-alive timeout

# ─────────────────────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────
# Protects against abuse and DoS attacks.
# Limits are per IP address.
RATE_LIMIT_REQUESTS=100     # Maximum requests per window
RATE_LIMIT_WINDOW=1m        # Time window (e.g., 1m, 5m, 1h)

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────
# Log level: debug | info | warn | error
# - debug: Very verbose, includes request details
# - info:  Normal operation messages
# - warn:  Potential issues
# - error: Error conditions only
LOG_LEVEL=info

# Log format
# - false: Human-readable (development)
# - true:  JSON format (production, for log aggregation)
LOG_JSON=false

# ─────────────────────────────────────────────────────────────────────────────
# WEB DASHBOARD (Next.js)
# ─────────────────────────────────────────────────────────────────────────────
# API URL for the frontend to connect to backend
# Must be accessible from the browser
NEXT_PUBLIC_API_URL=http://localhost:8080/v1

# WebSocket URL for real-time log streaming
NEXT_PUBLIC_WS_URL=ws://localhost:8080/v1/stream

# NextAuth.js configuration
# ⚠️  SECURITY: Generate a unique secret for production!
# Run: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret

# Full URL of your application (used for OAuth callbacks)
NEXTAUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# OAUTH PROVIDERS (Optional)
# ─────────────────────────────────────────────────────────────────────────────
# Enable social login with Google and GitHub.
# Leave empty to disable OAuth and use email/password only.

# Google OAuth
# Create credentials at: https://console.cloud.google.com/apis/credentials
# 1. Create a new OAuth 2.0 Client ID
# 2. Add authorized redirect URI: https://your-domain.com/api/auth/callback/google
# GOOGLE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxx

# GitHub OAuth
# Create app at: https://github.com/settings/developers
# 1. Create a new OAuth App
# 2. Set authorization callback URL: https://your-domain.com/api/auth/callback/github
# GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxx
# GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# BILLING (Optional - Paystack)
# ─────────────────────────────────────────────────────────────────────────────
# Paystack API keys for payment processing
# Get your keys at: https://dashboard.paystack.com/#/settings/developer
#
# PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxx
# PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
# PAYSTACK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
