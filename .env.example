# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║                          LOGSTACK CONFIGURATION                           ║
# ╠═══════════════════════════════════════════════════════════════════════════╣
# ║  Copy this file to .env and update the values for your environment.       ║
# ║  See: https://logstack.tech/docs/deployment/production-checklist         ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
# Connection string for PostgreSQL database.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=MODE
# 
# sslmode options:
#   - disable:     No SSL (development only)
#   - require:     SSL required (recommended for production)
#   - verify-full: SSL with certificate verification (most secure)
#
# Examples:
#   Local (Neon):  postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
#   Docker prod:   postgres://logstack:STRONG_PASSWORD@postgres:5432/logstack?sslmode=disable
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Connection pool settings (tune based on your workload)
DB_MAX_IDLE_CONNS=10        # Maximum idle connections in pool
DB_MAX_OPEN_CONNS=100       # Maximum open connections to database
DB_CONN_MAX_LIFE=30m        # Maximum lifetime of a connection

# ─────────────────────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────────────────────
# Connection string for Redis (used for caching, rate limiting, pub/sub).
# Format: redis://[:PASSWORD@]HOST:PORT[/DATABASE]
#
# Examples:
#   Local (Upstash): rediss://default:TOKEN@xxx.upstash.io:6379
#   Docker prod:     redis://redis:6379
REDIS_URL=rediss://default:TOKEN@xxx.upstash.io:6379
REDIS_POOL_SIZE=10          # Number of connections in Redis pool

# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION (JWT)
# ─────────────────────────────────────────────────────────────────────────────
# ⚠️  SECURITY: Generate unique secrets for production!
# Run: openssl rand -base64 32
#
# JWT_SECRET: Used to sign access and refresh tokens
# Must be at least 32 characters. Keep this secret!
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Token expiration times
# Format: Go duration (e.g., 15m, 1h, 24h, 7d)
ACCESS_TOKEN_EXPIRY=15m     # Short-lived access token (15 minutes recommended)
REFRESH_TOKEN_EXPIRY=168h   # Long-lived refresh token (7 days = 168h)

# Platform admins (comma-separated emails). Auto-promoted to role=admin on API startup.
# Existing users are promoted; missing users are created (password from ADMIN_SEED_PASSWORD
# or a one-time generated password logged at startup).
ADMIN_EMAILS=mosesedem81@gmail.com
ADMIN_SEED_PASSWORD=euytrtyuiuytf

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL NOTIFICATIONS
# ─────────────────────────────────────────────────────────────────────────────
# Multi-provider email delivery with automatic failover chain:
#   Mailcow (primary) → Brevo → Resend → Zoho (final fallback)
#
# Configure at least one provider. Providers with empty credentials are
# skipped silently. The system tries each provider in order until one succeeds.

# --- Mailcow (Self-Hosted Primary) ---
# Your self-hosted Mailcow instance. Acts as the primary email provider.
# Get the API key from: Mailcow Admin UI → API → Read/Write Access Key
# MAILCOW_API_KEY=your-mailcow-api-key
# MAILCOW_API_URL=https://mail.yourdomain.com

# --- Brevo (First Cloud Fallback) ---
# Transactional email SaaS. Used when Mailcow is unavailable.
# Get your API key at: https://app.brevo.com/settings/keys/api
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxxx

# --- Resend (Second Cloud Fallback) ---
# Transactional email SaaS. Used when both Mailcow and Brevo fail.
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx

# --- Zoho (Final Fallback) ---
# OAuth2-based transactional email. Used as the last resort provider.
# Create an OAuth client at: https://api-console.zoho.com/
# Grant the "ZohoMail.messages.CREATE" scope and generate a refresh token.
# ZOHO_CLIENT_ID=1000.xxxxxxxxxxxxx
# ZOHO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ZOHO_REFRESH_TOKEN=1000.xxxxxxxxxxxxx.xxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# PUSH NOTIFICATIONS (Firebase Cloud Messaging)
# ─────────────────────────────────────────────────────────────────────────────
# FCM HTTP v1 API credentials via a Firebase service account.
# The legacy FCM_SERVER_KEY is no longer used; the HTTP v1 API requires a
# service account JSON file authenticated with OAuth2.
#
# Steps:
#   1. Firebase Console → Project Settings → Service accounts
#   2. Generate a new private key and save the JSON file securely
#   3. Set FCM_SERVICE_ACCOUNT_PATH to the absolute path of that file
#   4. Set FCM_PROJECT_ID to your Firebase project ID (e.g. my-app-12345)
#
# Leave both empty to disable push notifications.
FCM_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json
FCM_PROJECT_ID=your-firebase-project-id

# ─────────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
PORT=8080                   # HTTP server port (inside the API container)

# EC2 / shared-host Docker: host port bound to the API container (container still uses 8080).
# Default 8082 avoids conflicts when 8080, 8081, 3000, 3001, 4000, 4040 are already taken.
API_HOST_PORT=8082

# Environment mode
# Options: development | production
# - development: Verbose logging, relaxed CORS
# - production:  JSON logging, strict security
ENV=development

# CORS allowed origins (comma-separated)
# ⚠️  SECURITY: Never use * in production!
# Examples:
#   Development: http://localhost:3000,http://localhost:8080
#   Production:  https://your-domain.com,https://www.your-domain.com
ALLOWED_ORIGINS=http://localhost:3000,https://logstack.tech,https://www.logstack.tech

# HTTP timeouts (prevent slow client attacks)
READ_TIMEOUT=15s            # Maximum time to read request
WRITE_TIMEOUT=15s           # Maximum time to write response
IDLE_TIMEOUT=60s            # Keep-alive timeout

# ─────────────────────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────
# Protects against abuse and DoS attacks.
# Limits are per IP address.
RATE_LIMIT_REQUESTS=100     # Maximum requests per window
RATE_LIMIT_WINDOW=1m        # Time window (e.g., 1m, 5m, 1h)

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────
# Log level: debug | info | warn | error
# - debug: Very verbose, includes request details
# - info:  Normal operation messages
# - warn:  Potential issues
# - error: Error conditions only
LOG_LEVEL=info

# Log format
# - false: Human-readable (development)
# - true:  JSON format (production, for log aggregation)
LOG_JSON=false

# ─────────────────────────────────────────────────────────────────────────────
# WEB DASHBOARD (Next.js)
# ─────────────────────────────────────────────────────────────────────────────
# API URL for the frontend to connect to backend
# Must be accessible from the browser
NEXT_PUBLIC_API_URL=http://localhost:8080/v1

# WebSocket URL for real-time log streaming
# Base path only (no /stream suffix) — the dashboard appends /stream.
NEXT_PUBLIC_WS_URL=ws://localhost:8080/v1

# NextAuth.js configuration
# ⚠️  SECURITY: Generate a unique secret for production!
# Run: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret

# Full URL of your application (used for OAuth callbacks)
NEXTAUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# OAUTH PROVIDERS (Optional)
# ─────────────────────────────────────────────────────────────────────────────
# Enable social login with Google and GitHub.
# Leave empty to disable OAuth and use email/password only.

# Google OAuth
# Create credentials at: https://console.cloud.google.com/apis/credentials
# 1. Create a new OAuth 2.0 Client ID
# 2. Add authorized redirect URI: https://your-domain.com/api/auth/callback/google
# GOOGLE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxx

# GitHub OAuth
# Create app at: https://github.com/settings/developers
# 1. Create a new OAuth App
# 2. Set authorization callback URL: https://your-domain.com/api/auth/callback/github
# GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxx
# GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# BILLING — Dual provider (Nigeria vs International)
# ─────────────────────────────────────────────────────────────────────────────
# Nigerian users (country=NG): Paystack subscriptions in NGN
# All other users: Polar subscriptions in USD (https://polar.sh/docs/introduction)

# Paystack (Nigeria / NGN) — https://dashboard.paystack.com/#/settings/developer
# Webhook URL: https://your-api-domain/v1/webhooks/paystack
# PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxx
# PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx
# PAYSTACK_WEBHOOK_URL=https://your-api-domain/v1/webhooks/paystack

# Polar (International / USD) — https://polar.sh/dashboard
# Create monthly subscription products for Starter and Pro tiers.
# Webhook URL: https://your-api-domain/v1/webhooks/polar
# POLAR_ACCESS_TOKEN=polar_pat_xxxxxxxxxxxxx
# POLAR_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
# POLAR_PRODUCT_STARTER=uuid-of-starter-product
# POLAR_PRODUCT_PRO=uuid-of-pro-product

