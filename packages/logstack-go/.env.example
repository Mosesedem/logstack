# Database Configuration
# Neon pooled connection (local dev)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFE=30m

# Redis Configuration
# Upstash TLS connection (local dev — use rediss:// not redis://)
REDIS_URL=rediss://default:TOKEN@xxx.upstash.io:6379
REDIS_POOL_SIZE=10

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=168h

# Email Notifications (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Firebase Cloud Messaging (FCM) - HTTP v1 API
# 1. Go to Firebase Console > Project Settings > Service Accounts
# 2. Click "Generate New Private Key" to download the JSON file
# 3. Place the JSON file in a secure location (e.g., /etc/secrets/firebase-service-account.json)
# 4. Set the path to this JSON file below
FCM_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json
# Optional: Project ID (can be inferred from service account file)
FCM_PROJECT_ID=your-firebase-project-id

# Server Configuration
PORT=8080
ENV=development
READ_TIMEOUT=15s
WRITE_TIMEOUT=15s
IDLE_TIMEOUT=60s

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# Logging
LOG_LEVEL=info
LOG_JSON=false

# Billing (Paystack)
# Get your API keys from: https://dashboard.paystack.com/settings/developer
# Test keys start with sk_test_ / pk_test_
# Live keys start with sk_live_ / pk_live_
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
PAYSTACK_WEBHOOK_URL=https://your-domain.com/api/webhooks/paystack

# Base URL for email links and callbacks
BASE_URL=http://localhost:3000

# Usage Tracking
USAGE_SYNC_INTERVAL=1m

# Email Notifications (Brevo/Sendinblue)
# Get your API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-xxxxxxxxxxxx
