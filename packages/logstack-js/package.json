{
  "name": "logstack-js",
  "version": "1.0.2",
  "description": "Logstack JavaScript/TypeScript SDK for log ingestion and querying",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "logstack",
    "logging",
    "logs",
    "monitoring",
    "observability"
  ],
  "author": "Mosesedem",
  "license": "MIT",
  "homepage": "https://github.com/Mosesedem/logstack/tree/main/packages/logstack-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mosesedem/logstack.git",
    "directory": "packages/logstack-js"
  },
  "bugs": {
    "url": "https://github.com/Mosesedem/logstack/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=16"
  }
}
